# Increase timeout to 600000ms (10 minutes) for slow/unstable networks
fetch-timeout=600000
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Optional optimizations to speed up installation
fund=false
audit=false

# Bypass strict SSL if network firewall/proxy is interfering (use with caution)
# strict-ssl=false
